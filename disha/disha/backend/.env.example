# Get a free Gemini API key (no credit card needed) at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: which Gemini model to use. Free tier: gemini-2.5-flash or gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# Allowed frontend origin for CORS (set to your deployed frontend URL in production)
FRONTEND_ORIGIN=http://localhost:5173
